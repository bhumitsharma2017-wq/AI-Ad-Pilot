# ========================
# SUPABASE
# ========================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ========================
# OPENAI
# ========================
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# ========================
# ANTHROPIC (Claude)
# ========================
ANTHROPIC_API_KEY=your_anthropic_api_key

# ========================
# RAZORPAY
# ========================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Razorpay Plan IDs — create these in Dashboard → Products → Plans
RAZORPAY_PRO_MONTHLY_PLAN_ID=plan_xxxxxxxxxxxxx
RAZORPAY_PRO_YEARLY_PLAN_ID=plan_xxxxxxxxxxxxx
RAZORPAY_AGENCY_MONTHLY_PLAN_ID=plan_xxxxxxxxxxxxx
RAZORPAY_AGENCY_YEARLY_PLAN_ID=plan_xxxxxxxxxxxxx

# ========================
# APP CONFIG
# ========================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AdPilot AI

# ========================
# SERPER / WEB SEARCH (for competitor analysis)
# ========================
SERPER_API_KEY=your_serper_api_key

# ========================
# FIRECRAWL (for website crawling)
# ========================
FIRECRAWL_API_KEY=your_firecrawl_api_key
